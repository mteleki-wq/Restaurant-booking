<script>
  const TOTAL = 14;
  let completed = new Set();

  function toggleCard(card) {
    const isOpen = card.classList.contains('open');
    card.classList.toggle('open', !isOpen);
  }

  function toggleCheck(e, checkEl) {
    e.stopPropagation();
    const card = checkEl.closest('.step-card');
    const id = Array.from(document.querySelectorAll('.step-card')).indexOf(card);
    checkEl.classList.toggle('checked');
    if (checkEl.classList.contains('checked')) {
      checkEl.textContent = '✓';
      card.classList.add('done');
      completed.add(id);
    } else {
      checkEl.textContent = '';
      card.classList.remove('done');
      completed.delete(id);
    }
    updateProgress();
  }

  function markDone(e, btn) {
    e.stopPropagation();
    const card = btn.closest('.step-card');
    const checkEl = card.querySelector('.step-check');
    const id = Array.from(document.querySelectorAll('.step-card')).indexOf(card);
    const nowDone = !btn.classList.contains('undone');
    btn.classList.toggle('undone', nowDone);
    btn.textContent = nowDone ? '↩ Mark as Incomplete' : '✓ Mark as Done';
    checkEl.classList.toggle('checked', nowDone);
    checkEl.textContent = nowDone ? '✓' : '';
    card.classList.toggle('done', nowDone);
    if (nowDone) completed.add(id); else completed.delete(id);
    updateProgress();
  }

  function updateProgress() {
    const n = completed.size;
    const pct = Math.round((n / TOTAL) * 100);
    document.getElementById('progressBar').style.width = pct + '%';
    document.getElementById('progressLabel').textContent = `${n} of ${TOTAL} completed`;
  }
</script>
